<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- LAYR khóa Dark mode + vẽ edge-to-edge. Nền cửa sổ tối để tránh chớp trắng
         lúc khởi động; status/navigation bar trong suốt để Compose vẽ tràn cạnh
         (enableEdgeToEdge cũng đặt lại lúc runtime, đây là dự phòng cho splash). -->
    <style name="Theme.Anhnnlayr" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/layr_background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="o_mr1">shortEdges</item>
    </style>
</resources>
